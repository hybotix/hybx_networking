# ── WiFi ──────────────────────────────────────────────────────────────────────
CONFIG_ESP32_WIFI_ENABLED=y
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP32_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP32_WIFI_TX_BUFFER_TYPE_DYNAMIC=y
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_ESP32_WIFI_AMPDU_TX_ENABLED=y
CONFIG_ESP32_WIFI_AMPDU_RX_ENABLED=y
CONFIG_ESP32_WIFI_NVS_ENABLED=y
CONFIG_ESP32_WIFI_TASK_PINNED_TO_CORE_0=y

# ── TCP/IP Stack (LwIP) ───────────────────────────────────────────────────────
CONFIG_LWIP_LOCAL_HOSTNAME="hybx-node"
CONFIG_LWIP_DHCP_MAX_NTP_SERVERS=3
CONFIG_LWIP_IPV4=y
CONFIG_LWIP_IPV6=y
CONFIG_LWIP_MAX_SOCKETS=16
CONFIG_LWIP_SO_REUSE=y
CONFIG_LWIP_SO_REUSE_RXTOALL=y
CONFIG_LWIP_SO_RCVBUF=y
CONFIG_LWIP_TCP_KEEPALIVE=y
CONFIG_LWIP_NETIF_LOOPBACK=y

# ── mDNS ──────────────────────────────────────────────────────────────────────
CONFIG_MDNS_MAX_SERVICES=10
CONFIG_MDNS_TASK_PRIORITY=1
CONFIG_MDNS_PREDEF_NETIF_STA=y

# ── MQTT ──────────────────────────────────────────────────────────────────────
CONFIG_MQTT_PROTOCOL_311=y
CONFIG_MQTT_TRANSPORT_SSL=y
CONFIG_MQTT_TRANSPORT_WEBSOCKET=y
CONFIG_MQTT_MSG_ID_INCREMENTAL=y
CONFIG_MQTT_OUTBOX_EXPIRED_TIMEOUT_MS=30000

# ── NVS (for credential storage) ─────────────────────────────────────────────
CONFIG_NVS_ASSERT_ERROR_CHECK=y

# ── FreeRTOS ──────────────────────────────────────────────────────────────────
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y

# ── Logging ───────────────────────────────────────────────────────────────────
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y
CONFIG_LOG_COLORS=y
CONFIG_LOG_TIMESTAMP_SOURCE_RTOS=y

# ── SNTP ──────────────────────────────────────────────────────────────────────
CONFIG_LWIP_SNTP_MAX_SERVERS=3

# ── ESP-NETIF ─────────────────────────────────────────────────────────────────
CONFIG_ESP_NETIF_IP_LOST_TIMER_INTERVAL=120

# ── Heap ──────────────────────────────────────────────────────────────────────
CONFIG_HEAP_TRACING_STANDALONE=y
